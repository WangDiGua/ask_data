#
# Base
#
NDEA_APP_NAME=NDEA
NDEA_ENV=development
NDEA_LOG_LEVEL=INFO

#
# Workflow
#
NDEA_WORKFLOW_RUNTIME=langgraph
NDEA_ENABLE_LEGACY_TOOLS=false

#
# Embedding
#
NDEA_EMBEDDING_PROVIDER=http
NDEA_EMBEDDING_BASE_URL=http://192.168.2.43:11434
NDEA_EMBEDDING_MODEL=bge-m3
NDEA_EMBEDDING_VECTOR_NAME=embedding

#
# Milvus
#
NDEA_MILVUS_URI=http://192.168.2.43:19530
NDEA_MILVUS_TOKEN=
NDEA_MILVUS_DATABASE=default
NDEA_MILVUS_COLLECTION=semantic_assets
NDEA_MILVUS_VECTOR_NAME=embedding
NDEA_MILVUS_SEARCH_LIMIT=5
NDEA_MILVUS_HYBRID_ENABLED=true
NDEA_MILVUS_HYBRID_OVERFETCH_LIMIT=20
NDEA_MILVUS_HYBRID_VECTOR_WEIGHT=0.65
NDEA_MILVUS_HYBRID_KEYWORD_WEIGHT=0.35
NDEA_MILVUS_HYBRID_EXACT_MATCH_BOOST=0.15
NDEA_MILVUS_COLLECTION_SQL_CASES=sql_cases
NDEA_MILVUS_COLLECTION_QUERY_MEMORY=query_memory

#
# MySQL
#
NDEA_MYSQL_HOST=192.168.2.43
NDEA_MYSQL_PORT=3306
NDEA_MYSQL_USER=root
NDEA_MYSQL_PASSWORD=root
NDEA_MYSQL_DATABASE=wenshu_db
NDEA_MYSQL_CONNECTION_BACKEND=sqlalchemy
NDEA_MYSQL_CONNECT_TIMEOUT=5
NDEA_MYSQL_READ_TIMEOUT=30
NDEA_MYSQL_QUERY_ROW_LIMIT=200
NDEA_MYSQL_EXPLAIN_ROW_LIMIT=100000
NDEA_SQLALCHEMY_POOL_SIZE=5
NDEA_SQLALCHEMY_MAX_OVERFLOW=10
NDEA_SQLALCHEMY_POOL_RECYCLE=1800
NDEA_SQLALCHEMY_POOL_PRE_PING=true

#
# Learning
#
NDEA_LEARNING_MYSQL_DATABASE=ndea_learning

#
# NL2SQL
#
NDEA_NL2SQL_ENGINE=llamaindex
NDEA_LLAMAINDEX_ENGINE_FACTORY=

#
# Observability
#
NDEA_LANGFUSE_PUBLIC_KEY=
NDEA_LANGFUSE_SECRET_KEY=
NDEA_LANGFUSE_HOST=https://cloud.langfuse.com

#
# Feature switches
#
NDEA_ENABLE_QUERY_EXECUTION=true
NDEA_ENABLE_SEMANTIC_RETRIEVAL=true

#
# Policy
#
NDEA_PERMISSION_ALLOWED_TABLES=
NDEA_PERMISSION_BLOCKED_COLUMNS=
NDEA_PERMISSION_MASKED_COLUMNS=
NDEA_PERMISSION_ROW_FILTERS=
